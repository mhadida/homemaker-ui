{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "build": {
      "entrypoint": "python/build.py",
      "routePrefix": "/build",
      "memory": 4096,
      "maxDuration": 30,
      "includeFiles": [
        "python/**/*.py",
        "python/vendor/homemaker-addon/**/*"
      ]
    }
  },
  "crons": [
    {
      "path": "/build",
      "schedule": "*/4 * * * *"
    }
  ]
}
